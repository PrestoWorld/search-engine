{
    "name": "prestoworld/search-engine",
    "description": "🚀 High-Performance Search Infrastructure for PrestoWorld CMS",
    "license": "MIT",
    "autoload": {
        "psr-4": {
            "Prestoworld\\SearchEngine\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Prestoworld\\SearchEngine\\Tests\\": "tests/"
        }
    },
    "authors": [
