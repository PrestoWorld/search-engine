            "name": "Puleeno Nguyen",
            "email": "puleeno@gmail.com"
        }
    ],
    "minimum-stability": "dev",
    "require": {
        "php": "^8.1",
        "witals/framework": "*",
        "teamtnt/tntsearch": "^2.9",
        "typesense/typesense-php": "^4.0",
        "meilisearch/meilisearch-php": "^1.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.0"
    },
    "prefer-stable": true
}